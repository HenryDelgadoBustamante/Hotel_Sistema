# Variables para PostgreSQL (docker-compose)
# DB_HOST=db activa automáticamente el motor PostgreSQL en settings.py
# Si DB_HOST está vacío o no definido, Django usará SQLite (desarrollo local sin Docker)
DB_NAME=hotel_db
DB_USER=hotel_admin
DB_PASSWORD=tu_contraseña_segura_aqui
DB_HOST=db
DB_PORT=5432
