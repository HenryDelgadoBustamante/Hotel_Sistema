# ============================================================
# ARCHIVO DE EJEMPLO - Copia esto como ".env" en la raíz
# ============================================================
# 1. Copia este archivo: cp .env.example .env  (o en Windows: copy .env.example .env)
# 2. Cambia los valores si lo necesitas (los de abajo funcionan tal cual para desarrollo)
# ============================================================

SECRET_KEY=django-insecure-cambia-esto-por-una-clave-segura
DEBUG=True

# Variables para PostgreSQL (docker-compose)
# DB_HOST=db activa automáticamente el motor PostgreSQL en settings.py
# Si DB_HOST está vacío, Django usará SQLite (desarrollo local sin Docker)
DB_NAME=hotel_db
DB_USER=hotel_admin
DB_PASSWORD=tu_contraseña_segura_aqui
DB_HOST=db
DB_PORT=5432
